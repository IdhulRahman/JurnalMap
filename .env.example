# ============================================================
# JurnalMap — Environment Variable Template
# Copy this file to `.env` at the project root and adjust values.
# ============================================================

# ── Application ────────────────────────────────────────────────────────
BACKEND_PORT=8001
FRONTEND_PORT=3000

# What the frontend calls (baked into JS bundle at build time)
REACT_APP_BACKEND_URL=http://localhost:8001

# CORS — restrict to your frontend domain in production
CORS_ORIGINS=http://localhost:3000

# ── MongoDB ─────────────────────────────────────────────────────────────────
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=changeme
DB_NAME=jurnalmap

# ── Auth / JWT ─────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change_me_in_production_please
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin
ADMIN_EMAIL=admin@jurnalmap.local

# ── LLM Provider (admin-side) ──────────────────────────────────────────────────────
# One of: gemini / openai / anthropic / local
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.0-flash

# Emergent Universal LLM Key (works for gemini/openai/anthropic via emergentintegrations)
EMERGENT_LLM_KEY=

# Or use vendor-native keys (leave EMERGENT_LLM_KEY empty and set the vendor key)
# GEMINI_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# ── Local LLM (Ollama / vLLM) ─────────────────────────────────────────────────────
# Enable to expose an admin-supplied local model in the UI dropdown.
LOCAL_LLM_ENABLED=false
LOCAL_LLM_NAME=gemma-llm
LOCAL_LLM_ENDPOINT=http://ollama:11434/v1
LOCAL_LLM_API_KEY=ollama

# ── Embedding model (Network Graph) ───────────────────────────────────────────────────
# When enabled, sentence-transformers is used for semantic similarity in the
# research network graph. If disabled (or if the model fails to load) JurnalMap
# falls back to a lightweight TF-cosine similarity.
EMBEDDING_ENABLED=true
# One of the following multilingual models (must match the architecture supported by sentence-transformers):
#   - paraphrase-multilingual-MiniLM-L12-v2   (~120MB, fast, recommended)
#   - intfloat/multilingual-e5-small          (~120MB, alternative)
#   - BAAI/bge-m3                             (~2GB, higher quality, heavy)
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# ── Uploads ────────────────────────────────────────────────────────────────────
MAX_FILES_PER_UPLOAD=5
MAX_UPLOAD_SIZE_MB=50

# ── Queue worker ─────────────────────────────────────────────────────────────────
# Concurrency is fixed at 1 by design. Polling interval (seconds):
QUEUE_POLL_INTERVAL=1.5
