# ============================================
# JurnalMap Configuration
# ============================================

# Application ports
BACKEND_PORT=8001
FRONTEND_PORT=3000

# What the frontend calls (baked into JS bundle at build time)
REACT_APP_BACKEND_URL=http://localhost:8001

# CORS — restrict to your frontend domain in production
CORS_ORIGINS=http://localhost:3000

# ============================================
# MongoDB
# ============================================
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=changeme
DB_NAME=jurnalmap

# ============================================
# Auth / JWT
# ============================================
# Generate a strong secret: openssl rand -hex 32
JWT_SECRET_KEY=change_me_in_production_please
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin
ADMIN_EMAIL=admin@jurnalmap.local

# ============================================
# Local LLM (Ollama / vLLM) — Admin Only
# ============================================

# Set to "true" to enable a local LLM provided by the server administrator
LOCAL_LLM_ENABLED=false

# Display name shown in the model dropdown
LOCAL_LLM_NAME=gemma-llm

# OpenAI-compatible base URL (Ollama default: http://ollama:11434/v1)
OPENAI_BASE_URL=http://ollama:11434/v1

# Model name to load via the local endpoint (e.g. llama3.1:8b, gemma2:9b)
LOCAL_LLM_MODEL=llama3.1:8b

# API key for local endpoint (leave as "ollama" for Ollama default)
LOCAL_LLM_API_KEY=ollama

# ============================================
# Embedding Model (Network Graph)
# ============================================

# HuggingFace sentence-transformers model name
# Options:
#   paraphrase-multilingual-MiniLM-L12-v2  (~120MB, multilingual, recommended)
#   intfloat/multilingual-e5-small          (~120MB, multilingual, alternative)
#   all-MiniLM-L6-v2                        (~80MB, English only)
EMBEDDING_ENABLED=true
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# ============================================
# Upload limits
# ============================================
MAX_FILES_PER_UPLOAD=5
MAX_UPLOAD_SIZE_MB=50

# ============================================
# Queue worker
# ============================================
# Concurrency is fixed at 1. Polling interval in seconds:
QUEUE_POLL_INTERVAL=1.5
